# Nach .env kopieren und anpassen. .env wird von `docker compose up`
# automatisch eingelesen.

# Port, unter dem das Dashboard auf dem Host erreichbar ist.
PORT=4000

# Optional: legt beim allerersten Start automatisch einen aktiven
# Admin-Account an, damit man sich nicht erst manuell registrieren und
# selbst freischalten muss. Wirkt NUR beim ersten Start (leere/neue
# Datenbank) - ändert man das Passwort später im Dashboard, bleibt diese
# Änderung auch nach einem Neustart des Containers bestehen.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=bitte-aendern
